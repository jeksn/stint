{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stint",
  "version": "0.1.0",
  "identifier": "com.jeksn.stint",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Stint",
        "width": 500,
        "height": 400,
        "minWidth": 400,
        "minHeight": 350,
        "resizable": true
      },
      {
        "label": "settings",
        "title": "Stint Settings",
        "width": 480,
        "height": 400,
        "visible": false,
        "center": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
